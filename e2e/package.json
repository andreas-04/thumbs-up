{
  "name": "thumbs-up-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end tests for ThumbsUp using Playwright + Cucumber/Gherkin",
  "scripts": {
    "bddgen": "bddgen",
    "test": "bddgen && playwright test",
    "test:report": "playwright show-report",
    "test:ui": "bddgen && playwright test --ui"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.7.0",
    "@playwright/test": "1.58.2",
    "@types/node": "22.14.0",
    "playwright-bdd": "8.4.2",
    "tsx": "4.21.0",
    "typescript": "5.8.3"
  }
}
